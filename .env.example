# 本番URL (sitemap.xml / robots.txt / OGP の metadataBase に使用)
# Vercel の production 環境変数にも同値を設定してください
NEXT_PUBLIC_SITE_URL=https://www.thepicklebang.com

# メンテナンスモード (teaser ページにリダイレクトする)
NEXT_PUBLIC_MAINTENANCE=false

# Resend (お問い合わせフォームのメール送信)
RESEND_API_KEY=
RESEND_FROM=
CONTACT_TO_EMAIL=

# microCMS (ニュース CMS)
# サービス名 (https://${MICROCMS_SERVICE_DOMAIN}.microcms.io の部分)
MICROCMS_SERVICE_DOMAIN=
# 読み取り API キー (Vercel Production 環境変数に設定)
MICROCMS_API_KEY=
# Webhook 署名検証用シークレット (microCMS 管理画面 > API > Webhook で設定したものと一致させる)
MICROCMS_WEBHOOK_SECRET=
# プレビュー入口 (/api/draft/enable) の secret パラメータ検証用
MICROCMS_DRAFT_SECRET=
# (任意) プレビュー入口の Origin allowlist (カンマ区切り、未設定で全許可)
MICROCMS_DRAFT_ALLOWED_ORIGINS=

# CMS ニュース機能フラグ (true で有効化、それ以外は旧ハードコード表示)
USE_CMS_NEWS=false
